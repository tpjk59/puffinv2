# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# USDA FoodData Central — free key at https://fdc.nal.usda.gov/api-guide.html
# Defaults to DEMO_KEY (30 req/hour). Get your own for higher limits.
USDA_API_KEY=DEMO_KEY

# Database — defaults to local SQLite
DATABASE_URL=sqlite+aiosqlite:///./meal_planner.db

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Web dashboard auth (HTTP Basic Auth — set a strong password)
WEB_USERNAME=puffin
WEB_PASSWORD=

# Telegram webhook secret — sent as X-Telegram-Bot-Api-Secret-Token header
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# After setting, run: python cli.py register-webhook https://<your-host>/webhook/telegram
TELEGRAM_WEBHOOK_SECRET=

# MacroFactor MCP server
# URL of the deployed puffin-mcp server (see macrofactor-mcp/fly.toml — app "puffin-mcp")
# Typically https://puffin-mcp.fly.dev/mcp for the streamable-HTTP endpoint
# If not set, nutrition tracking is silently disabled in the agent.
MACROFACTOR_MCP_URL=
# Optional Bearer token if your MCP server requires authentication (leave blank if open)
MACROFACTOR_MCP_TOKEN=

# Food source URLs
VEG_BOX_URL=
MEAT_BOX_URL=
